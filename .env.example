# ===== App / DB =====
APP_NAME=watermelon-backend
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/watermelon

# ===== Azure Blob (마스터 데이터셋 = 예측 입력) =====
BLOB_STORAGE_URL=https://<account>.blob.core.windows.net/
BLOB_STORAGE_ACCESS_KEY=<access-key>
BLOB_CONTAINER_NAME=data
BLOB_DATASET_BLOB=watermelon_dataset_targets.csv

# ===== 예측 스케줄 (인앱) =====
PREDICTION_CRON_HOUR=3
PREDICTION_CRON_MINUTE=0
PREDICTION_TIMEZONE=Asia/Seoul

# ===== 데이터 수집 파이프라인 =====
# 유가 (오피넷)
OPINET_API_KEY=
OPINET_BACKFILL_START=20200101
# CPI (KOSIS)
KOSIS_API_KEY=
KOSIS_USER_ID=
# 기상 (기상청 KMA ASOS authKey)
AGRI_WEATHER_SERVICE_KEY=
# 가락시장 반입량 (data22)
GARAK_API_ID=
GARAK_API_PASSWD=
# 가락시장 단위별 도매가 (data36)
GARAK_PRICE_ID=
GARAK_PRICE_PASSWD=
# 도매가 물가보정 기준 CPI (0=최신 발표월 자동)
CPI_BASE=0.0
# 데이터 수집 스케줄 (로컬 scheduler.py용; 예측 전 완료되도록 2시)
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_HOUR=2
SCHEDULER_MINUTE=0
